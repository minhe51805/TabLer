{
  "name": "tabler",
  "private": true,
  "version": "0.1.5",
  "releaseLabel": "0.1.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings=64",
    "check:frontend": "npm run typecheck && npm run lint && npm run test:run && npm run build",
    "check:release-contract": "node scripts/check-release-contract.mjs",
    "check:tauri-target": "node scripts/check-tauri-binary-target.mjs",
    "check:sql-splitter": "node scripts/check-sql-splitter.mjs && cargo test sql_splitter_contract --manifest-path src-tauri/Cargo.toml",
    "build:release": "tauri build --config src-tauri/tauri.release.conf.json",
    "build:e2e": "tauri build --debug --no-bundle --features e2e --config src-tauri/tauri.e2e.conf.json",
    "test:e2e": "node e2e/run.mjs",
    "test:performance": "vitest run tests/performance/v015-performance.test.ts",
    "check:secrets": "node scripts/check-secret-leaks.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-updater": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-is": "^19.2.5",
    "recharts": "^3.8.1",
    "sql-formatter": "^15.7.3",
    "tailwindcss": "^4.2.1",
    "write-excel-file": "^4.1.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@axe-core/webdriverio": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@wdio/cli": "9.27.0",
    "@wdio/globals": "9.27.0",
    "@wdio/local-runner": "9.27.0",
    "@wdio/mocha-framework": "9.27.0",
    "@wdio/spec-reporter": "9.27.0",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "dompurify": "^3.4.12",
    "serialize-javascript": "^7.0.5",
    "@wdio/native-utils": "2.5.0"
  }
}
