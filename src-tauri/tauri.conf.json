{
  "productName": "TableR",
  "version": "0.1.0",
  "identifier": "com.tabler.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TableR",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "center": true,
        "visible": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob: filesystem:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://api.github.com; font-src 'self' data:; worker-src 'self' blob:; child-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["tabler"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/minhe51805/TabLer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGQTg4RjQxRkZGRDdGOUYKUldTZmYvMy9RWStvWDIzbkx3Z3ovMEFwSS84ODZKY2xuc0MrRDVMUkN0REVZdkYwVFViODFPTWwK"
    }
  }
}
