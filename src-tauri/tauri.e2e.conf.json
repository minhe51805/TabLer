{
  "build": {
    "beforeBuildCommand": "npm run build -- --mode e2e",
    "devUrl": null,
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "e2e",
          "description": "Debug-only WebdriverIO bridge for desktop smoke tests",
          "windows": ["main"],
          "permissions": ["wdio:default"]
        }
      ]
    }
  }
}
